#!/usr/bin/env bash
# gcloud stub for workload-identity test suite
# Simulates successful responses for all gcloud subcommands used by the script.

args=("$@")
cmd_str="$*"

case "$cmd_str" in
    "auth list"*|"auth list --filter"*)
        echo "test-user@example.com"
        exit 0
        ;;
    "auth application-default print-access-token"*)
        echo "fake-token-for-testing"
        exit 0
        ;;
    "config get-value project"*)
        echo "test-project-01"
        exit 0
        ;;
    "config get-value account"*)
        echo "test-user@example.com"
        exit 0
        ;;
    "projects describe"*)
        # Simulate project exists
        echo "name: ${args[-1]}"
        exit 0
        ;;
    "container clusters list"*)
        # Return one test cluster
        printf "test-cluster\tus-central1\n"
        exit 0
        ;;
    "container clusters get-credentials"*)
        exit 0
        ;;
    "iam service-accounts describe"*)
        echo "displayName: test-sa"
        exit 0
        ;;
    "iam service-accounts create"*)
        exit 0
        ;;
    "iam service-accounts add-iam-policy-binding"*)
        exit 0
        ;;
    "iam service-accounts list"*)
        exit 0
        ;;
    "storage cp"*)
        exit 0
        ;;
    *)
        exit 0
        ;;
esac
